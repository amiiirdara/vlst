{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":16069376,"datasetId":10304639,"databundleVersionId":17037989},{"sourceType":"datasetVersion","sourceId":16068108,"datasetId":10303829,"databundleVersionId":17036619},{"sourceType":"kernelVersion","sourceId":316213549}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# TabPFN follow-up on FP-mining cohort (VLST)\n\nTrains a **TabPFN** classifier on a **balanced** subset of the **test** split from `fp_precision_mining.ipynb`:\n\n- **All** rows with **positive** labels (`y_test == 1`).\n- **Negatives** count **equals** the positive count: prefer rows from **`false_positives_union_test.csv`** (gathered false-positive potential on test), then fill with **true negatives** (test negatives not appearing in that union export). If union-negatives outnumber positives, a random subset of union-negatives is drawn (`VLST_TABPFN_FOLLOWUP_SEED`).\n\n**Inputs:** FP export bundle (`fp_mining_bundle.joblib` or NPZ+meta) and **`VLST_FP_OUTPUT_DIR`** / **`VLST_FP_RUN_TAG`** so **`false_positives_union_test.csv`** resolves like `fp_precision_mining.ipynb`.\n\n**Metrics:** ROC-AUC, PR-AUC, accuracy, classification report, confusion matrices on **test** at probability **0.5**, at **validation F1-max threshold**, and at **validation F0.5-max threshold** (`sklearn.metrics.fbeta_score(..., beta=0.5)` — common when people write “F0”; plain **F1** is the other tuned threshold).\n\n**Env:** `TABPFN_TOKEN` (same as `advanced` §8b), optional `VLST_FP_INPUT_ROOT`, `VLST_FP_OUTPUT_DIR`, `VLST_FP_RUN_TAG`.\n","metadata":{}},{"cell_type":"markdown","source":"## 1. Paths and imports\n","metadata":{}},{"cell_type":"code","source":"import os\nos.environ[\"VLST_FP_INPUT_ROOT\"] = \"/kaggle/input/datasets/amirmahdidaraei/vlst-fp-inputs/vlst_fp_inputs\"\n# or the full file path:\nos.environ[\"VLST_FP_OUTPUT_DIR\"] = \"/kaggle/input/datasets/amirmahdidaraei/fp-output/vlst_fp_mining_output\"","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-04T12:11:31.318994Z","iopub.execute_input":"2026-05-04T12:11:31.319225Z","iopub.status.idle":"2026-05-04T12:11:31.326238Z","shell.execute_reply.started":"2026-05-04T12:11:31.319201Z","shell.execute_reply":"2026-05-04T12:11:31.325401Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"os.environ[\"TABPFN_TOKEN\"] = \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyIjoiNjMwZGUxYjEtMzJhMy00OWQ1LWJiZGMtNzAxYjgyZWM5MTM1IiwiZXhwIjoxODA3MzgwNzk3fQ.fPW78VeHhNf8ys9xObX7xjz8SNzw4U6qGDJTYL6NZx4\"\nif os.environ.get(\"TABPFN_TOKEN\"):\n    print(\"TABPFN_TOKEN set for this kernel.\")\nelse:\n    print(\"Skipped — export TABPFN_TOKEN in the shell or TabPFN will stay off in 8b.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"!pip install tabpfn","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport warnings\nfrom glob import glob\n\nimport joblib\nimport numpy as np\nimport pandas as pd\nfrom sklearn.metrics import (\n    ConfusionMatrixDisplay,\n    accuracy_score,\n    average_precision_score,\n    classification_report,\n    confusion_matrix,\n    f1_score,\n    fbeta_score,\n    precision_score,\n    recall_score,\n    roc_auc_score,\n)\nfrom sklearn.model_selection import train_test_split\n\nwarnings.filterwarnings(\"ignore\", category=UserWarning)\n\nRANDOM_STATE = int(os.environ.get(\"VLST_TABPFN_FOLLOWUP_SEED\", \"42\"))\n\n# --- FP mining export (same artifacts as fp_precision_mining §1) ---\ndef _has_fp_artifacts(root: str) -> bool:\n    b = os.path.join(root, \"fp_mining_bundle.joblib\")\n    m = os.path.join(root, \"deploy_winner_meta.json\")\n    z = os.path.join(root, \"deploy_winner_arrays.npz\")\n    return os.path.isfile(b) or (os.path.isfile(m) and os.path.isfile(z))\n\n\ndef _discover_fp_root_under_kaggle_input():\n    base = \"/kaggle/input\"\n    if not os.path.isdir(base):\n        return None\n    for hit in sorted(glob(os.path.join(base, \"**\", \"fp_mining_bundle.joblib\"), recursive=True)):\n        d = os.path.abspath(os.path.dirname(hit))\n        if _has_fp_artifacts(d):\n            return d\n    for meta_path in sorted(glob(os.path.join(base, \"**\", \"deploy_winner_meta.json\"), recursive=True)):\n        d = os.path.abspath(os.path.dirname(meta_path))\n        if os.path.isfile(os.path.join(d, \"deploy_winner_arrays.npz\")):\n            return d\n    return None\n\n\ndef pick_fp_input_root() -> str:\n    env = os.environ.get(\"VLST_FP_INPUT_ROOT\") or os.environ.get(\"VLST_ADVANCED_RESULT_DIR\")\n    if env:\n        p = os.path.expanduser(env.rstrip(os.sep))\n        if not _has_fp_artifacts(p):\n            raise FileNotFoundError(f\"No fp_mining export at VLST_FP_INPUT_ROOT={p!r}\")\n        return p\n    if os.path.isdir(\"/kaggle/working/vlst_fp_inputs\") and _has_fp_artifacts(\"/kaggle/working/vlst_fp_inputs\"):\n        return \"/kaggle/working/vlst_fp_inputs\"\n    g = _discover_fp_root_under_kaggle_input()\n    if g:\n        return g\n    repo = os.path.normpath(os.path.join(\"..\", \"..\", \"data\", \"result\", \"modeling_advanced\"))\n    if _has_fp_artifacts(repo):\n        return repo\n    raise FileNotFoundError(\n        \"Set VLST_FP_INPUT_ROOT to the folder with fp_mining_bundle.joblib (or NPZ+meta).\"\n    )\n\n\ndef pick_fp_mining_output_dir(bundle_root: str) -> str:\n    \"\"\"Match fp_precision_mining: default output is fp_mining under bundle result on disk, or /kaggle/working/vlst_fp_mining_output on Kaggle.\"\"\"\n    out = os.environ.get(\"VLST_FP_OUTPUT_DIR\") or os.environ.get(\"VLST_FP_MINING_OUT\")\n    if out:\n        out = os.path.expanduser(out.rstrip(os.sep))\n    elif os.path.isdir(\"/kaggle/working\"):\n        out = \"/kaggle/working/vlst_fp_mining_output\"\n    else:\n        out = os.path.join(bundle_root, \"fp_mining\")\n    tag = os.environ.get(\"VLST_FP_RUN_TAG\", \"\").strip()\n    if tag:\n        out = os.path.join(out, tag)\n    return out\n\n\nINPUT_ROOT = pick_fp_input_root()\nFP_MINING_OUT = pick_fp_mining_output_dir(INPUT_ROOT)\nUNION_CSV = os.path.join(FP_MINING_OUT, \"false_positives_union_test.csv\")\n\nprint(\"INPUT_ROOT (bundle):\", INPUT_ROOT)\nprint(\"FP mining outputs (union CSV):\", FP_MINING_OUT)\nprint(\"Union CSV:\", UNION_CSV)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-04T12:11:31.327822Z","iopub.execute_input":"2026-05-04T12:11:31.328112Z","iopub.status.idle":"2026-05-04T12:11:35.452533Z","shell.execute_reply.started":"2026-05-04T12:11:31.328083Z","shell.execute_reply":"2026-05-04T12:11:35.451611Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 2. Load bundle + union CSV, build balanced cohort\n","metadata":{}},{"cell_type":"code","source":"def load_bundle(input_root: str):\n    bpath = os.path.join(input_root, \"fp_mining_bundle.joblib\")\n    zpath = os.path.join(input_root, \"deploy_winner_arrays.npz\")\n    mpath = os.path.join(input_root, \"deploy_winner_meta.json\")\n    if os.path.isfile(bpath):\n        B = joblib.load(bpath)\n        return B, \"joblib\"\n    if os.path.isfile(zpath) and os.path.isfile(mpath):\n        import json\n        with open(mpath, encoding=\"utf-8\") as f:\n            meta = json.load(f)\n        z = np.load(zpath)\n        B = {\n            \"X_test\": np.asarray(z[\"X_test\"]),\n            \"y_test\": np.asarray(z[\"y_test\"]).astype(int).ravel(),\n            \"feature_names\": list(meta[\"feature_names\"]),\n        }\n        return B, \"npz\"\n    raise FileNotFoundError(bpath)\n\n\nB, _src = load_bundle(INPUT_ROOT)\nX_test = np.asarray(B[\"X_test\"])\ny_test = np.asarray(B[\"y_test\"]).astype(int).ravel()\nfeature_names = list(B.get(\"feature_names\", []))\nn = X_test.shape[0]\n\nif not os.path.isfile(UNION_CSV):\n    raise FileNotFoundError(\n        f\"Missing {UNION_CSV}. Run fp_precision_mining.ipynb first or set VLST_FP_OUTPUT_DIR / VLST_FP_RUN_TAG.\"\n    )\n\ndf_union = pd.read_csv(UNION_CSV)\nif \"test_row_id\" not in df_union.columns:\n    raise ValueError(\"Union CSV must contain test_row_id.\")\n\ngathered = set(df_union[\"test_row_id\"].astype(int).tolist())\ngathered_neg = np.array([i for i in gathered if 0 <= i < n and y_test[i] == 0], dtype=int)\ntn_pool = np.array(\n    [i for i in range(n) if y_test[i] == 0 and i not in gathered],\n    dtype=int,\n)\n\npos_idx = np.flatnonzero(y_test == 1)\nn_pos = int(pos_idx.size)\nif n_pos == 0:\n    raise ValueError(\"No positive labels in y_test.\")\n\nrng = np.random.RandomState(RANDOM_STATE)\nneg_selected = []\nneed = n_pos\n\ngn = np.unique(gathered_neg)\nif gn.size <= need:\n    neg_selected.extend(gn.tolist())\n    short = need - len(neg_selected)\n    if short > 0:\n        if tn_pool.size < short:\n            raise ValueError(\n                f\"Need {short} true negatives but only {tn_pool.size} available. \"\n                \"Reduce positives scope or union FP size.\"\n            )\n        neg_selected.extend(rng.choice(tn_pool, size=short, replace=False).tolist())\nelse:\n    neg_selected.extend(rng.choice(gn, size=need, replace=False).tolist())\n\nneg_selected = np.array(sorted(set(neg_selected)), dtype=int)\nassert neg_selected.size == n_pos\n\nidx = np.concatenate([pos_idx, neg_selected])\nrng.shuffle(idx)\n\nX_cohort = np.asarray(X_test[idx], dtype=np.float32)\ny_cohort = np.asarray(y_test[idx], dtype=int)\n\nprint(\n    \"Cohort | positives:\", n_pos,\n    \"| negatives:\", n_pos,\n    \"| union-negs used:\", len(np.intersect1d(neg_selected, gn)),\n    \"| TN filled:\", len(neg_selected) - len(np.intersect1d(neg_selected, gn)),\n)\nprint(\"Features:\", X_cohort.shape[1], \"| rows:\", X_cohort.shape[0])\n","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 3. Train / validation / test split + TabPFN\n","metadata":{}},{"cell_type":"code","source":"X_tr, X_temp, y_tr, y_temp = train_test_split(\n    X_cohort, y_cohort, test_size=0.3, stratify=y_cohort, random_state=RANDOM_STATE\n)\nX_val, X_te, y_val, y_te = train_test_split(\n    X_temp, y_temp, test_size=0.5, stratify=y_temp, random_state=RANDOM_STATE\n)\n\nprint(\"Train / val / test:\", X_tr.shape[0], X_val.shape[0], X_te.shape[0])\n\ntoken = os.environ.get(\"TABPFN_TOKEN\")\nif not token:\n    raise RuntimeError(\n        \"Set TABPFN_TOKEN (shell export, Kaggle secret, or os.environ) — same as advanced.ipynb §8b.\"\n    )\n\ntry:\n    import torch\nexcept ImportError:\n    torch = None\n\nTABPFN_N_ESTIMATORS = int(os.environ.get(\"TABPFN_N_ESTIMATORS\", \"8\"))\nTABPFN_DEVICE = os.environ.get(\"TABPFN_DEVICE\")\nif not TABPFN_DEVICE:\n    TABPFN_DEVICE = \"cuda\" if torch is not None and torch.cuda.is_available() else \"cpu\"\n\nfrom tabpfn import TabPFNClassifier\n\nclf = TabPFNClassifier(\n    random_state=RANDOM_STATE,\n    n_estimators=TABPFN_N_ESTIMATORS,\n    device=TABPFN_DEVICE,\n    ignore_pretraining_limits=True,\n    balance_probabilities=True,\n)\nclf.fit(X_tr, y_tr)\n\np_val = clf.predict_proba(X_val)[:, 1]\np_te = clf.predict_proba(X_te)[:, 1]\n\nprint(\"TabPFN fit OK | device:\", TABPFN_DEVICE)\n","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 4. Thresholds (validation): max F1 and max F0.5 — metrics + confusion matrices on **test**\n","metadata":{}},{"cell_type":"code","source":"import matplotlib.pyplot as plt\n\nt_grid = np.arange(0.01, 1.0, 0.01)\n\n\ndef best_threshold(y_true, p, grid, metric_fn):\n    best_t, best_v = 0.5, -1.0\n    for t in grid:\n        y_hat = (p >= t).astype(int)\n        v = float(metric_fn(y_true, y_hat))\n        if v > best_v:\n            best_v, best_t = v, float(t)\n    return best_t, best_v\n\n\ndef f1m(y, yhat):\n    return f1_score(y, yhat, zero_division=0)\n\n\ndef f05m(y, yhat):\n    return fbeta_score(y, yhat, beta=0.5, zero_division=0)\n\n\nt_f1, v_f1_val = best_threshold(y_val, p_val, t_grid, f1m)\nt_f05, v_f05_val = best_threshold(y_val, p_val, t_grid, f05m)\n\nprint(\"Validation | best threshold for max F1:\", round(t_f1, 4), \"| F1 at that t:\", round(v_f1_val, 4))\nprint(\n    \"Validation | best threshold for max F0.5 (fbeta, beta=0.5 — not 'F0'; use if you wanted precision tilt):\",\n    round(t_f05, 4),\n    \"| F0.5 at that t:\",\n    round(v_f05_val, 4),\n)\n\ny_hat_05 = (p_te >= 0.5).astype(int)\ny_hat_f1 = (p_te >= t_f1).astype(int)\ny_hat_f05 = (p_te >= t_f05).astype(int)\n\n\ndef report_block(name, y_true, y_hat, p):\n    print(\"\\n===\", name, \"===\")\n    print(\"ROC-AUC:\", round(roc_auc_score(y_true, p), 4))\n    print(\"PR-AUC:\", round(average_precision_score(y_true, p), 4))\n    print(\"Accuracy:\", round(accuracy_score(y_true, y_hat), 4))\n    print(\n        \"Precision / Recall / F1:\",\n        round(precision_score(y_true, y_hat, zero_division=0), 4),\n        round(recall_score(y_true, y_hat, zero_division=0), 4),\n        round(f1_score(y_true, y_hat, zero_division=0), 4),\n    )\n    print(classification_report(y_true, y_hat, digits=4))\n    cm = confusion_matrix(y_true, y_hat)\n    print(\"Confusion matrix [[TN FP] / [FN TP]]:\\n\", cm)\n    plt.figure(figsize=(4, 3.5))\n    ConfusionMatrixDisplay(cm).plot(cmap=\"Blues\")\n    plt.title(name)\n    plt.tight_layout()\n    plt.show()\n\n\nreport_block(\"Test @ threshold 0.5\", y_te, y_hat_05, p_te)\nreport_block(\"Test @ t = F1-max on validation\", y_te, y_hat_f1, p_te)\nreport_block(\"Test @ t = F0.5-max on validation\", y_te, y_hat_f05, p_te)\n\nsummary = {\n    \"t_f1_max_val\": float(t_f1),\n    \"t_f05_max_val\": float(t_f05),\n    \"val_f1_at_t_f1\": float(v_f1_val),\n    \"val_f05_at_t_f05\": float(v_f05_val),\n    \"n_train\": int(X_tr.shape[0]),\n    \"n_val\": int(X_val.shape[0]),\n    \"n_test\": int(X_te.shape[0]),\n}\nprint(\"\\nSummary:\", summary)\n","metadata":{},"outputs":[],"execution_count":null}]}