    "import matplotlib.pyplot as plt\n",
    "\n",
    "t_grid = np.arange(0.01, 1.0, 0.01)\n",
    "\n",
    "\n",
    "def best_threshold(y_true, p, grid, metric_fn):\n",
    "    best_t, best_v = 0.5, -1.0\n",
    "    for t in grid:\n",
    "        y_hat = (p >= t).astype(int)\n",
    "        v = float(metric_fn(y_true, y_hat))\n",
    "        if v > best_v:\n",
    "            best_v, best_t = v, float(t)\n",
    "    return best_t, best_v\n",
    "\n",
    "\n",
    "def f1m(y, yhat):\n",
    "    return f1_score(y, yhat, zero_division=0)\n",
    "\n",
    "\n",
    "def f05m(y, yhat):\n",
    "    return fbeta_score(y, yhat, beta=0.5, zero_division=0)\n",
    "\n",
    "\n",
    "t_f1, v_f1_val = best_threshold(y_val, p_val, t_grid, f1m)\n",
    "t_f05, v_f05_val = best_threshold(y_val, p_val, t_grid, f05m)\n",
    "\n",
    "print(\"Validation | best threshold for max F1:\", round(t_f1, 4), \"| F1 at that t:\", round(v_f1_val, 4))\n",
    "print(\n",
    "    \"Validation | best threshold for max F0.5 (fbeta, beta=0.5 — not 'F0'; use if you wanted precision tilt):\",\n",
    "    round(t_f05, 4),\n",
    "    \"| F0.5 at that t:\",\n",
    "    round(v_f05_val, 4),\n",
    ")\n",
    "\n",
    "y_hat_05 = (p_te >= 0.5).astype(int)\n",
    "y_hat_f1 = (p_te >= t_f1).astype(int)\n",
    "y_hat_f05 = (p_te >= t_f05).astype(int)\n",
    "\n",
    "\n",
    "def report_block(name, y_true, y_hat, p):\n",
    "    print(\"\\n===\", name, \"===\")\n",
    "    print(\"ROC-AUC:\", round(roc_auc_score(y_true, p), 4))\n",
    "    print(\"PR-AUC:\", round(average_precision_score(y_true, p), 4))\n",
    "    print(\"Accuracy:\", round(accuracy_score(y_true, y_hat), 4))\n",
    "    print(\n",
    "        \"Precision / Recall / F1:\",\n",
    "        round(precision_score(y_true, y_hat, zero_division=0), 4),\n",
    "        round(recall_score(y_true, y_hat, zero_division=0), 4),\n",
    "        round(f1_score(y_true, y_hat, zero_division=0), 4),\n",
    "    )\n",
    "    print(classification_report(y_true, y_hat, digits=4))\n",
    "    cm = confusion_matrix(y_true, y_hat)\n",
    "    print(\"Confusion matrix [[TN FP] / [FN TP]]:\\n\", cm)\n",
    "    plt.figure(figsize=(4, 3.5))\n",
    "    ConfusionMatrixDisplay(cm).plot(cmap=\"Blues\")\n",
    "    plt.title(name)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "report_block(\"Test @ threshold 0.5\", y_te, y_hat_05, p_te)\n",
    "report_block(\"Test @ t = F1-max on validation\", y_te, y_hat_f1, p_te)\n",
    "report_block(\"Test @ t = F0.5-max on validation\", y_te, y_hat_f05, p_te)\n",
    "\n",
    "summary = {\n",
    "    \"t_f1_max_val\": float(t_f1),\n",
    "    \"t_f05_max_val\": float(t_f05),\n",
    "    \"val_f1_at_t_f1\": float(v_f1_val),\n",
    "    \"val_f05_at_t_f05\": float(v_f05_val),\n",
    "    \"n_train\": int(X_tr.shape[0]),\n",
    "    \"n_val\": int(X_val.shape[0]),\n",
    "    \"n_test\": int(X_te.shape[0]),\n",
    "}\n",
    "print(\"\\nSummary:\", summary)\n"
