    "def load_bundle(input_root: str):\n",
    "    bpath = os.path.join(input_root, \"fp_mining_bundle.joblib\")\n",
    "    zpath = os.path.join(input_root, \"deploy_winner_arrays.npz\")\n",
    "    mpath = os.path.join(input_root, \"deploy_winner_meta.json\")\n",
    "    if os.path.isfile(bpath):\n",
    "        B = joblib.load(bpath)\n",
    "        return B, \"joblib\"\n",
    "    if os.path.isfile(zpath) and os.path.isfile(mpath):\n",
    "        import json\n",
    "        with open(mpath, encoding=\"utf-8\") as f:\n",
    "            meta = json.load(f)\n",
    "        z = np.load(zpath)\n",
    "        B = {\n",
    "            \"X_test\": np.asarray(z[\"X_test\"]),\n",
    "            \"y_test\": np.asarray(z[\"y_test\"]).astype(int).ravel(),\n",
    "            \"feature_names\": list(meta[\"feature_names\"]),\n",
    "        }\n",
    "        return B, \"npz\"\n",
    "    raise FileNotFoundError(bpath)\n",
    "\n",
    "\n",
    "B, _src = load_bundle(INPUT_ROOT)\n",
    "X_test = np.asarray(B[\"X_test\"])\n",
    "y_test = np.asarray(B[\"y_test\"]).astype(int).ravel()\n",
    "feature_names = list(B.get(\"feature_names\", []))\n",
    "n = X_test.shape[0]\n",
    "\n",
    "if not os.path.isfile(UNION_CSV):\n",
    "    raise FileNotFoundError(\n",
    "        f\"Missing {UNION_CSV}. Run fp_precision_mining.ipynb first or set VLST_FP_OUTPUT_DIR / VLST_FP_RUN_TAG.\"\n",
    "    )\n",
    "\n",
    "df_union = pd.read_csv(UNION_CSV)\n",
    "if \"test_row_id\" not in df_union.columns:\n",
    "    raise ValueError(\"Union CSV must contain test_row_id.\")\n",
    "\n",
    "# All test indices that fp_mining flagged in the union export (predicted-positive / FP-mined negatives)\n",
    "gathered_ids = set(df_union[\"test_row_id\"].astype(int).tolist())\n",
    "\n",
    "# Mined \"false positive\" negatives: label 0 and appears in union\n",
    "fp_mined_neg = np.array(\n",
    "    sorted({i for i in gathered_ids if 0 <= i < n and y_test[i] == 0}),\n",
    "    dtype=int,\n",
    ")\n",
    "\n",
    "# True negative pool: label 0, not among mined union rows (either solution: mine TNs or skip-in-FP-set)\n",
    "tn_pool = np.array(\n",
    "    [i for i in range(n) if y_test[i] == 0 and i not in gathered_ids],\n",
    "    dtype=int,\n",
    ")\n",
    "\n",
    "pos_idx = np.flatnonzero(y_test == 1)\n",
    "n_pos = int(pos_idx.size)\n",
    "if n_pos == 0:\n",
    "    raise ValueError(\"No positive labels in y_test.\")\n",
    "\n",
    "rng = np.random.RandomState(RANDOM_STATE)\n",
    "if tn_pool.size < n_pos:\n",
    "    raise ValueError(\n",
    "        f\"Need {n_pos} true negatives (to match positive count) but only {tn_pool.size} \"\n",
    "        \"label-0 rows are outside the union CSV. Widen test or relax union.\"\n",
    "    )\n",
    "tn_sample_idx = rng.choice(tn_pool, size=n_pos, replace=False)\n",
    "\n",
    "# Cohort: ALL positives + ALL fp_mined union negatives + n_pos sampled true negatives\n",
    "idx = np.concatenate([pos_idx, fp_mined_neg, tn_sample_idx])\n",
    "idx = np.unique(idx)\n",
    "\n",
    "X_cohort = np.asarray(X_test[idx], dtype=np.float32)\n",
    "y_cohort = np.asarray(y_test[idx], dtype=int)\n",
    "\n",
    "n_fp = int(fp_mined_neg.size)\n",
    "print(\n",
    "    \"Cohort | positives (y=1):\", n_pos,\n",
    "    \"| mined union negatives (y=0, in union CSV):\", n_fp,\n",
    "    \"| true negatives sampled (= n_pos):\", n_pos,\n",
    "    \"| total rows:\", X_cohort.shape[0],\n",
    ")\n",
    "print(\n",
    "    \"  (TN = test negatives with y=0 whose test_row_id is NOT in false_positives_union_test.csv)\"\n",
    ")\n",
    "print(\"Features:\", X_cohort.shape[1])\n"
