    "t_grid = np.arange(0.05, 0.96, 0.01)\n",
    "\n",
    "\n",
    "def best_threshold_f1(y_true, p, grid):\n",
    "    best_t, best_f1 = 0.5, -1.0\n",
    "    for t in grid:\n",
    "        y_hat = (p >= t).astype(int)\n",
    "        fv = f1_score(y_true, y_hat, zero_division=0)\n",
    "        if fv > best_f1:\n",
    "            best_f1, best_t = fv, float(t)\n",
    "    return best_t, float(best_f1)\n",
    "\n",
    "\n",
    "t_winner, f1w = best_threshold_f1(y_cal, p_cal_w, t_grid)\n",
    "pred_w_te = (p_te_w >= t_winner).astype(int)\n",
    "fp_winner = (y_test == 0) & (pred_w_te == 1)\n",
    "\n",
    "print(\n",
    "    \"Winner model | F1-max threshold (cal):\",\n",
    "    round(t_winner, 4),\n",
    "    \"| cal F1 at t:\",\n",
    "    round(f1w, 4),\n",
    ")\n",
    "print(\n",
    "    \"Test | FP (y=0 & pred=1):\",\n",
